# VanAssist deployment credentials (FTP to GoDaddy cPanel).
#
# Copy this file to "deploy.env" in the same folder and fill in the values.
# deploy.env is gitignored and must NEVER be committed.
#
# These are the same FTP credentials used to reach the condrendigital.com.au
# hosting account (host/user/password as supplied by GoDaddy / cPanel).

FTP_HOST=184.168.99.174
FTP_USER=glen@condrendigital.com.au
FTP_PASSWORD=your-ftp-password-here

# Use explicit TLS (FTPS) if the account supports it; otherwise false for plain FTP.
FTP_SECURE=false

# Remote path of the VanAssist PROJECT ROOT as the FTP user sees it.
# The subdomain serves the app from <REMOTE_PATH> (which routes into /public).
DEPLOY_REMOTE_PATH=/vanassist
