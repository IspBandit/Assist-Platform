# =====================================================================
# VanAssist environment configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit a real .env file to version control.
# =====================================================================

APP_NAME=VanAssist
APP_ENV=production
APP_DEBUG=false
APP_URL=https://vanassist.com.au
APP_KEY=
APP_RELEASE=

# Assist Platform brand resolution. Keep strict host checks off until every
# production/preview hostname is registered and tested.
ASSIST_DEFAULT_BRAND=vanassist
ASSIST_BRAND=
ASSIST_STRICT_BRAND_HOSTS=true
ASSIST_ALLOW_BRAND_QUERY=false

# Brand domains and deployment URLs
VANASSIST_DOMAIN=vanassist.com.au
VANASSIST_URL=https://vanassist.com.au
VANASSIST_LEGAL_NAME=VanAssist
VANASSIST_SUPPORT_EMAIL=
VANASSIST_ANALYTICS_ID=

TOWSMART_URL=https://towsmart.com.au
TOWSMART_DOMAIN=towsmart.com.au
TOWSMART_LEGAL_NAME=TowSmart
TOWSMART_SUPPORT_EMAIL=
TOWSMART_MAIL_FROM_ADDRESS=support@towsmart.com.au
TOWSMART_ANALYTICS_ID=

TRAILERWISE_URL=https://trailerwise.com.au
TRAILERWISE_DOMAIN=trailerwise.com.au
TRAILERWISE_LEGAL_NAME=TrailerWise
TRAILERWISE_SUPPORT_EMAIL=
TRAILERWISE_MAIL_FROM_ADDRESS=support@trailerwise.com.au
TRAILERWISE_ANALYTICS_ID=

# Initial launch mode: private | provider-onboarding | local-pilot | public
LAUNCH_MODE=private

# Database (MySQL 8 / MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Sessions
SESSION_LIFETIME=120
SESSION_SECURE=true
# Exact reverse-proxy IPs allowed to supply X-Forwarded-For/Proto, comma-separated.
TRUSTED_PROXIES=

# Mail (queued, processed by cron). Do NOT rely on PHP mail().
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=VanAssist
MAIL_MAX_ATTEMPTS=3

# Cloudflare Turnstile (optional bot protection)
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Uploads / images
MAX_REQUEST_IMAGES=6
MAX_IMAGE_UPLOAD_MB=8
MAX_DOCUMENT_UPLOAD_MB=10
IMAGE_MAX_WIDTH=1800
IMAGE_MAX_DIMENSION=12000
IMAGE_MAX_PIXELS=24000000
THUMBNAIL_WIDTH=480

# Feature flags
ENABLE_SMS=false
ENABLE_REVIEWS=false
ENABLE_PUBLIC_PHONE=false

# Billing / monetisation (all OFF for the free launch).
# The database tables and services exist, but nothing is charged or shown
# while these are false. Toggle on later without rebuilding provider data.
ENABLE_BILLING=false
ENABLE_PROVIDER_SUBSCRIPTIONS=false
ENABLE_PROVIDER_TRIALS=false
ENABLE_FEATURED_LISTINGS=false
ENABLE_FEATURED_RUNS=false
ENABLE_BOOKING_FEES=false
ENABLE_COMMISSIONS=false
ENABLE_CUSTOMER_PAYMENTS=false
ENABLE_PROVIDER_PAYOUTS=false
ENABLE_DISCOUNT_CODES=false
ENABLE_ANNUAL_BILLING=false

# Billing gateway: none | stripe  (use "none" while ENABLE_BILLING=false)
BILLING_GATEWAY=none
BILLING_CURRENCY=AUD
# Default free plan slug new providers fall back to (must exist in billing_plans).
BILLING_DEFAULT_FREE_PLAN=founding_free
# Days of access retained after a failed payment before paid features lock.
BILLING_GRACE_DAYS=14

# Stripe (only used when BILLING_GATEWAY=stripe). Never store raw card data.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# GST / Australian tax invoice defaults (review with an accountant before launch)
GST_REGISTERED=false
GST_RATE=10
BILLING_ABN=
BILLING_BUSINESS_NAME=VanAssist
GST_INCLUSIVE_PRICING=true
INVOICE_NUMBER_PREFIX=VA-

# Backups
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=3

# Security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
ADMIN_SESSION_TIMEOUT=30
